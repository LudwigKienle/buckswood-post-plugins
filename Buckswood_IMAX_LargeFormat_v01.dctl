        active_grain_sat      = 0.15f * (grain_sat / 0.5f);
        active_grain_bias     = -0.25f + grain_bias * 0.25f;
        active_silver_flicker = 0.02f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.75f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.03f * (chroma_soft / 0.1f);
