// ====================================================================
// Buckswood IMAX / Large Format Film Emulation
// Based on the stable Buckswood Film Emulation DCTL
// Designed for working inside DaVinci Wide Gamut / Intermediate
// Inspired by Cullen Kelly Color Science & Hollywood Film Physics
// ====================================================================

// Define Input Color Space Options
// 0 = DaVinci Wide Gamut / Intermediate (DWG/DI)
// 1 = Sony S-Log3 / S-Gamut3.Cine
// 2 = ARRI LogC3
// 3 = ARRI LogC4
// 4 = Apple Log
// 5 = AI Footage / Rec.709
DEFINE_UI_PARAMS(input_space, "Input Space", DCTLUI_COMBO_BOX, 0, { DWG_DI, SONY_SLOG3, ARRI_LOGC3, ARRI_LOGC4, APPLE_LOG, REC709_AI }, { "DaVinci Wide Gamut", "Sony S-Log3", "ARRI LogC3", "ARRI LogC4", "Apple Log", "AI Footage (Rec.709)" })

// Define Output Color Space Options
// 0 = Bypass (Keep DWG/DI)
// 1 = Rec.709 (Gamma 2.4)
// 2 = DCI-P3 (Gamma 2.6)
// 3 = Rec.2020 (Gamma 2.4)
DEFINE_UI_PARAMS(output_space, "Output Space", DCTLUI_COMBO_BOX, 0, { BYPASS_OUT, REC709_OUT, DCIP3_OUT, REC2020_OUT }, { "Bypass (Keep DWG/DI)", "Rec.709 (Gamma 2.4)", "DCI-P3 (Gamma 2.6)", "Rec.2020 (Gamma 2.4)" })

// Define Preset Combo Box options
// 0 = Manual/Custom
// 1 = Kodak 2383 Print Emulation
// 2 = Fuji 3513 Print Emulation
// 3 = Kodak 5219 (Vision3 500T) Negative Emulation
// 4 = Agfa JT 12.5 Vintage Print Emulation
// 5 = Fuji Superia 400 Consumer Negative Emulation
// 6 = Kodak Ektachrome 100D Color Reversal Slide Film
// 7 = Kodak Tri-X 400 Gritty Black & White Film
// 8 = Polaroid 600 Nostalgic Instant Vintage Film
// 9 = Kodak Vision3 250D Daylight Cinema Negative
// 10 = Fuji Velvia 50 Ultra-Vivid Color Slide Film
// 11 = Kodak Kodachrome 64 Legendary Vintage Slide
// 12 = Ilford HP5 Plus 400 Classic Fine-Art B&W
// 13 = CineStill 800T Tungsten Halation Cinema Look
// 14 = Kodak Gold 200 Warm Golden Consumer negative
// 15 = Kodak Portra 400 Professional Portrait Negative
// 16 = Kodak Portra 160 Low Contrast Fashion Pastels
// 17 = Kodak Ektar 100 Ultra Vivid Finest Grain Negative
// 18 = CineStill 50D Daylight Cinema Halation Look
// 19 = Fuji Pro 400H Soft Pastel Wedding Slide Look
// 20 = Fuji Astia 100F Natural Balanced Portrait Slide
// 21 = Fuji Provia 100F Clean Daylight Color Slide
// 22 = Agfaphoto Vista 400 Saturated Primary Reds Look
// 23 = Lomography CN 800 Saturated Retro Warm Look
// 24 = Lomography Metropolis Desaturated Cold Gray Look
// 25 = Lomography Purple false-color Violet Dreamscape
// 26 = ORWO UN54 Historic German B&W Cinema Movie Film
// 27 = Fomapan 100 Czech Retro High Contrast B&W Film
// 28 = Ilford Delta 3200 Extreme High Grain Gritty B&W
// 29 = Kodak Aerochrome Infrared false-color Hot foliage Look
// 30 = Technicolor 2-Strip Vintage 1920s Movie Look
// 31 = IMAX 15/70 Clean Large Format
// 32 = IMAX Digital Large Format Clean
// 33 = IMAX Night Large Format
// 34 = IMAX Warm Print Large Format
DEFINE_UI_PARAMS(preset, "Film Profile", DCTLUI_COMBO_BOX, 0, { CUSTOM, KODAK_2383, FUJI_3513, KODAK_5219, AGFA_JT12, FUJI_SUPERIA, EKTACHROME, TRIX_400, POLAROID, KODAK_250D, FUJI_VELVIA, KODACHROME, ILFORD_HP5, CINESTILL_800T, KODAK_GOLD, PORTRA_400, PORTRA_160, EKTAR_100, CINESTILL_50D, FUJI_PRO400H, ASTIA_100F, PROVIA_100F, VISTA_400, LOMO_800, METROPOLIS, LOMO_PURPLE, ORWO_UN54, FOMAPAN_100, DELTA_3200, AEROCHROME, TECHNICOLOR_2STRIP, IMAX_1570_CLEAN, IMAX_DLF_CLEAN, IMAX_NIGHT, IMAX_WARM_PRINT }, { "Manual / Custom", "Kodak 2383 Print", "Fuji 3513 Print", "Kodak 5219 Negative", "Agfa JT 12.5 Print", "Fuji Superia 400", "Ektachrome 100D Slide", "Kodak Tri-X 400 B&W", "Polaroid 600 Vintage", "Kodak Vision3 250D Cinema", "Fuji Velvia 50 Slide", "Kodak Kodachrome 64", "Ilford HP5 Plus 400 B&W", "CineStill 800T Cinema", "Kodak Gold 200", "Kodak Portra 400", "Kodak Portra 160", "Kodak Ektar 100", "CineStill 50D Cinema", "Fuji Pro 400H", "Fuji Astia 100F", "Fuji Provia 100F", "Agfaphoto Vista 400", "Lomography CN 800", "Lomography Metropolis", "Lomography Purple", "ORWO UN54 B&W Cinema", "Fomapan 100 B&W", "Ilford Delta 3200 B&W", "Kodak Aerochrome IR", "Technicolor 2-Strip", "IMAX 15/70 Clean", "IMAX DLF Clean", "IMAX Night", "IMAX Warm Print" })



// Define UI sliders for the DaVinci Resolve color page interface
DEFINE_UI_PARAMS(contrast, "Contrast", DCTLUI_SLIDER_FLOAT, 1.0, 0.5, 2.0, 0.01)
DEFINE_UI_PARAMS(saturation, "Saturation", DCTLUI_SLIDER_FLOAT, 1.0, 0.0, 2.0, 0.01)

// Subtractive Film CMY Dye Density Sliders (Dye Absorption Layer Emulation)
DEFINE_UI_PARAMS(density_c, "Cyan Dye Density", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(density_m, "Magenta Dye Density", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(density_y, "Yellow Dye Density", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)

// Subtractive Film Dye Crosstalk Sliders (Normalized 3x3 Mixer)
DEFINE_UI_PARAMS(crosstalk_rg, "Red Green Crosstalk", DCTLUI_SLIDER_FLOAT, 0.0, -0.2, 0.2, 0.01)
DEFINE_UI_PARAMS(crosstalk_rb, "Red Blue Crosstalk", DCTLUI_SLIDER_FLOAT, 0.0, -0.2, 0.2, 0.01)
DEFINE_UI_PARAMS(crosstalk_gb, "Green Blue Crosstalk", DCTLUI_SLIDER_FLOAT, 0.0, -0.2, 0.2, 0.01)

// Hollywood Localized 3D HSL Warp Sliders
DEFINE_UI_PARAMS(skin_warm, "Skin Tone Warmth", DCTLUI_SLIDER_FLOAT, 0.0, -1.0, 1.0, 0.01)
DEFINE_UI_PARAMS(shadow_cool, "Shadow Cooling", DCTLUI_SLIDER_FLOAT, 0.0, -1.0, 1.0, 0.01)

// Film Halation Glow & Highlight Gate Bloom Sliders
DEFINE_UI_PARAMS(halation, "Film Halation Glow", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(gate_bloom, "Highlight Gate Bloom", DCTLUI_SLIDER_FLOAT, 0.1, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(highlight_roll, "Highlight Soft Roll-off", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)

// Film Grain & Silver Flicker Sliders
DEFINE_UI_PARAMS(grain_amount, "Film Grain Amount", DCTLUI_SLIDER_FLOAT, 0.1, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(grain_size, "Film Grain Size", DCTLUI_SLIDER_FLOAT, 1.0, 0.5, 2.5, 0.01)
DEFINE_UI_PARAMS(grain_sat, "Film Grain Saturation", DCTLUI_SLIDER_FLOAT, 0.5, 0.0, 2.0, 0.01)
DEFINE_UI_PARAMS(grain_bias, "Film Grain Bias", DCTLUI_SLIDER_FLOAT, 0.0, -1.0, 1.0, 0.01)
DEFINE_UI_PARAMS(silver_flicker, "Silver Density Flicker", DCTLUI_SLIDER_FLOAT, 0.1, 0.0, 1.0, 0.01)

// Hollywood Masterpiece Advanced Extension Sliders
DEFINE_UI_PARAMS(hl_desat, "Highlight Desaturation", DCTLUI_SLIDER_FLOAT, 0.2, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(chroma_soft, "Chroma Edge Softening", DCTLUI_SLIDER_FLOAT, 0.1, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(gate_weave, "Micro Gate Weave", DCTLUI_SLIDER_FLOAT, 0.1, 0.0, 1.0, 0.01)
DEFINE_UI_PARAMS(grain_seed, "Grain Seed / Animate", DCTLUI_SLIDER_FLOAT, 1.0, 1.0, 1000.0, 0.1)

// --------------------------------------------------------------------
// High-Performance 3D Bitwise Integer Hash Function (MurmurHash3 Finalizer)
// Returns a highly uniform pseudo-random float strictly in range [0.0f, 1.0f)
// 100% free of spatial repeating patterns, grids, Moire banding, or float precision loss.
// --------------------------------------------------------------------
__DEVICE__ float hash3d(int x, int y, int z) {
    // 1. Spatial prime mixers (completely decorrelates spatial positions)
    unsigned int h = (unsigned int)x * 73856093 ^ (unsigned int)y * 19349663 ^ (unsigned int)z * 83492791;
    
    // 2. MurmurHash3 32-bit finalizer integer mix
    h ^= h >> 16;
    h *= 0x85ebca6b;
    h ^= h >> 13;
    h *= 0xc2b2ae35;
    h ^= h >> 16;
    
    // 3. Float normalization in [0.0f, 1.0f) using 24-bit mantissa mask
    return (float)(h & 0xffffff) / 16777216.0f;
}

// --------------------------------------------------------------------
// Input Color Space Curve Translators
// Natively converts camera-specific log curves to DaVinci Intermediate
// --------------------------------------------------------------------
__DEVICE__ float slog3_to_linear(float y) {
    return (y >= 0.09f) ? (_powf(10.0f, (y - 0.5616868f) / 0.26968f) * 1.01f) - 0.01f : 2.637817f * (y - 0.09f) + 0.0105f;
}

__DEVICE__ float logc3_to_linear(float y) {
    return (y >= 0.1496582f) ? (_powf(2.0f, (y - 0.385537f) / 0.0625f) - 1.0f) * 0.18f + 0.005f : (y - 0.096582f) / 5.0f;
}

__DEVICE__ float logc4_to_linear(float y) {
    return (y >= 0.0798604f) ? (_powf(2.0f, (y - 0.4960307f) / 0.075936f) - 0.010543f) / 222.9562f : (y - 0.0798604f) / 1084.477f - 0.000188f;
}

__DEVICE__ float apple_log_to_linear(float y) {
    if (y >= 0.208555f) {
        return _powf(2.0f, (y - 0.69336945f) / 0.08550479f) - 0.00964052f;
    } else {
        return -0.05641088f + _sqrtf(_fmaxf(0.0f, y) / 47.28711236f);
    }
}

__DEVICE__ float rec709_to_linear(float y) {
    return _powf(_fmaxf(0.0f, y), 2.4f);
}

// DaVinci Intermediate Log conversion using natural logs (100% compilable)
__DEVICE__ float linear_to_di(float x) {
    float safe_x = (x < 0.0f) ? 0.0f : x;
    return (_logf(safe_x + 0.0075f) / 0.693147f + 10.0f) / 15.0f;
}

// Inverse DaVinci Intermediate Log conversion back to scene-linear
__DEVICE__ float di_to_linear(float y) {
    return _powf(2.0f, y * 15.0f - 10.0f) - 0.0075f;
}

// Target Display gamma mapping (Gamma 2.4 / Rec.709 / Rec.2020)
__DEVICE__ float linear_to_gamma24(float x) {
    float safe_x = (x < 0.0f) ? 0.0f : x;
    return _powf(safe_x, 1.0f / 2.4f);
}

// Target Display gamma mapping (Gamma 2.6 / DCI-P3)
__DEVICE__ float linear_to_gamma26(float x) {
    float safe_x = (x < 0.0f) ? 0.0f : x;
    return _powf(safe_x, 1.0f / 2.6f);
}

// --------------------------------------------------------------------
// Main DCTL Transform Entry Point
// --------------------------------------------------------------------
__DEVICE__ float3 transform(int p_Width, int p_Height, int p_X, int p_Y, float p_R, float p_G, float p_B) 
{
    float3 rgb = make_float3(p_R, p_G, p_B);

    // ----------------------------------------------------------------
    // INPUT COLOR SPACE CONVERSION (Auto-Decoding to DWG/DI)
    // ----------------------------------------------------------------
    if (input_space == SONY_SLOG3) {
        float r_lin = slog3_to_linear(rgb.x);
        float g_lin = slog3_to_linear(rgb.y);
        float b_lin = slog3_to_linear(rgb.z);
        
        // S-Gamut3.Cine to DWG Gamut Mapping
        float r_dwg = 0.99665004f * r_lin - 0.02673953f * g_lin + 0.03008948f * b_lin;
        float g_dwg = 0.00896200f * r_lin + 0.92530063f * g_lin + 0.06573737f * b_lin;
        float b_dwg = 0.06802042f * r_lin + 0.09770487f * g_lin + 0.83427471f * b_lin;
        
        rgb.x = linear_to_di(r_dwg);
        rgb.y = linear_to_di(g_dwg);
        rgb.z = linear_to_di(b_dwg);
    } else if (input_space == ARRI_LOGC3) {
        float r_lin = logc3_to_linear(rgb.x);
        float g_lin = logc3_to_linear(rgb.y);
        float b_lin = logc3_to_linear(rgb.z);
        
        // ARRI AWG3 to DWG Gamut Mapping
        float r_dwg = 0.88505905f * r_lin + 0.10359396f * g_lin + 0.01134707f * b_lin;
        float g_dwg = 0.06922668f * r_lin + 0.91943144f * g_lin + 0.01134190f * b_lin;
        float b_dwg = 0.07536832f * r_lin + 0.05279615f * g_lin + 0.87183573f * b_lin;
        
        rgb.x = linear_to_di(r_dwg);
        rgb.y = linear_to_di(g_dwg);
        rgb.z = linear_to_di(b_dwg);
    } else if (input_space == ARRI_LOGC4) {
        float r_lin = logc4_to_linear(rgb.x);
        float g_lin = logc4_to_linear(rgb.y);
        float b_lin = logc4_to_linear(rgb.z);
        
        // ARRI AWG4 to DWG Gamut Mapping
        float r_dwg = 0.99739594f * r_lin - 0.02316501f * g_lin + 0.02576908f * b_lin;
        float g_dwg = -0.00918307f * r_lin + 0.91763203f * g_lin + 0.09155105f * b_lin;
        float b_dwg = 0.07348799f * r_lin + 0.09370480f * g_lin + 0.83280721f * b_lin;
        
        rgb.x = linear_to_di(r_dwg);
        rgb.y = linear_to_di(g_dwg);
        rgb.z = linear_to_di(b_dwg);
    } else if (input_space == APPLE_LOG) {
        float r_lin = apple_log_to_linear(rgb.x);
        float g_lin = apple_log_to_linear(rgb.y);
        float b_lin = apple_log_to_linear(rgb.z);
        
        // BT.2020 to DWG Gamut Mapping (Apple Log uses Rec.2020 primaries)
        float r_dwg = 0.89211211f * r_lin + 0.02436930f * g_lin + 0.08351867f * b_lin;
        float g_dwg = 0.03261636f * r_lin + 0.78613744f * g_lin + 0.18124622f * b_lin;
        float b_dwg = 0.06997703f * r_lin + 0.10474972f * g_lin + 0.82527344f * b_lin;
        
        rgb.x = linear_to_di(r_dwg);
        rgb.y = linear_to_di(g_dwg);
        rgb.z = linear_to_di(b_dwg);
    } else if (input_space == REC709_AI) {
        float r_lin = rec709_to_linear(rgb.x);
        float g_lin = rec709_to_linear(rgb.y);
        float b_lin = rec709_to_linear(rgb.z);
        
        // Rec.709 to DWG Gamut Mapping
        float r_dwg = 0.56285696f * r_lin + 0.32350914f * g_lin + 0.11368869f * b_lin;
        float g_dwg = 0.07776709f * r_lin + 0.74956007f * g_lin + 0.17262659f * b_lin;
        float b_dwg = 0.06467950f * r_lin + 0.19199424f * g_lin + 0.74315377f * b_lin;
        
        rgb.x = linear_to_di(r_dwg);
        rgb.y = linear_to_di(g_dwg);
        rgb.z = linear_to_di(b_dwg);
    }


    // ----------------------------------------------------------------
    // FILM PROFILE PRESET MAPPING (Tweakable Preset Architecture)
    // ----------------------------------------------------------------
    float active_contrast       = contrast;
    float active_density_c      = density_c;
    float active_density_m      = density_m;
    float active_density_y      = density_y;
    float active_saturation     = saturation;
    float active_crosstalk_rg   = crosstalk_rg;
    float active_crosstalk_rb   = crosstalk_rb;
    float active_crosstalk_gb   = crosstalk_gb;
    float active_skin_warm      = skin_warm;
    float active_shadow_cool    = shadow_cool;
    float active_halation       = halation;
    float active_gate_bloom     = gate_bloom;
    float active_highlight_roll  = highlight_roll;
    float active_grain_amount   = grain_amount;
    float active_grain_size     = grain_size;
    float active_grain_sat      = grain_sat;
    float active_grain_bias     = grain_bias;
    float active_silver_flicker  = silver_flicker;
    float active_hl_desat       = hl_desat;
    float active_chroma_soft    = chroma_soft;
    float active_gate_weave     = gate_weave;
    float active_grain_seed     = grain_seed;

    if (preset == KODAK_2383) {
        // Kodak 2383: Heavy density, warm skin-crosstalk, cool shadow wash, subtle grain
        active_contrast       = 1.22f * contrast;
        active_density_c      = 0.35f + (density_c - 0.2f);
        active_density_m      = 0.38f + (density_m - 0.2f);
        active_density_y      = 0.30f + (density_y - 0.2f);
        active_saturation     = 0.95f * saturation;
        active_crosstalk_rg   = 0.07f + crosstalk_rg;
        active_crosstalk_rb   = 0.02f + crosstalk_rb;
        active_crosstalk_gb   = -0.04f + crosstalk_gb;
        active_skin_warm      = 0.15f + skin_warm;
        active_shadow_cool    = 0.30f + shadow_cool;          // Hollywood contrast shadows
        active_halation       = 0.25f * (halation / 0.2f);
        active_gate_bloom     = 0.20f * (gate_bloom / 0.1f);
        active_highlight_roll  = 0.30f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.12f * (grain_amount / 0.1f);
        active_grain_size     = 1.20f * grain_size;
        active_grain_sat      = 0.60f * (grain_sat / 0.5f);
        active_grain_bias     = -0.40f + grain_bias;
        active_silver_flicker  = 0.15f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.40f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.15f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.20f * (gate_weave / 0.1f);
    } else if (preset == FUJI_3513) {
        // Fuji 3513: High contrast, emerald/cyan highlight crosstalk, coarser grain
        active_contrast       = 1.28f * contrast;
        active_density_c      = 0.40f + (density_c - 0.2f);
        active_density_m      = 0.35f + (density_m - 0.2f);
        active_density_y      = 0.38f + (density_y - 0.2f);
        active_saturation     = 1.05f * saturation;
        active_crosstalk_rg   = -0.05f + crosstalk_rg;
        active_crosstalk_rb   = -0.02f + crosstalk_rb;
        active_crosstalk_gb   = 0.08f + crosstalk_gb;
        active_skin_warm      = -0.05f + skin_warm;
        active_shadow_cool    = 0.20f + shadow_cool;
        active_halation       = 0.20f * (halation / 0.2f);
        active_gate_bloom     = 0.15f * (gate_bloom / 0.1f);
        active_highlight_roll  = 0.25f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.15f * (grain_amount / 0.1f);
        active_grain_size     = 1.40f * grain_size;
        active_grain_sat      = 0.40f * (grain_sat / 0.5f);
        active_grain_bias     = -0.20f + grain_bias;
        active_silver_flicker  = 0.10f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.30f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.10f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.15f * (gate_weave / 0.1f);
    } else if (preset == KODAK_5219) {
        // Kodak 5219 (500T): Creamy negative contrast, highly subtractive density, organic soft grain
        active_contrast       = 0.85f * contrast;
        active_density_c      = 0.48f + (density_c - 0.2f);
        active_density_m      = 0.42f + (density_m - 0.2f);
        active_density_y      = 0.45f + (density_y - 0.2f);
        active_saturation     = 1.05f * saturation;
        active_crosstalk_rg   = 0.02f + crosstalk_rg;
        active_crosstalk_rb   = 0.04f + crosstalk_rb;
        active_crosstalk_gb   = -0.02f + crosstalk_gb;
        active_skin_warm      = 0.25f + skin_warm;            // Creamy skin tones
        active_shadow_cool    = 0.10f + shadow_cool;
        active_halation       = 0.35f * (halation / 0.2f);    // Noticeable halogen glow
        active_gate_bloom     = 0.30f * (gate_bloom / 0.1f);  // Dynamic lens scatter
        active_highlight_roll  = 0.45f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.18f * (grain_amount / 0.1f);
        active_grain_size     = 1.50f * grain_size;
        active_grain_sat      = 0.70f * (grain_sat / 0.5f);
        active_grain_bias     = -0.60f + grain_bias;
        active_silver_flicker  = 0.20f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.60f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.35f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.35f * (gate_weave / 0.1f);
    } else if (preset == AGFA_JT12) {
        // Agfa JT 12.5 Print: Low density, stylized desaturated pastels, cooler shadows
        active_contrast       = 1.15f * contrast;
        active_density_c      = 0.25f + (density_c - 0.2f);
        active_density_m      = 0.28f + (density_m - 0.2f);
        active_density_y      = 0.32f + (density_y - 0.2f);
        active_saturation     = 0.80f * saturation;
        active_crosstalk_rg   = 0.05f + crosstalk_rg;
        active_crosstalk_rb   = -0.06f + crosstalk_rb;
        active_crosstalk_gb   = 0.04f + crosstalk_gb;
        active_skin_warm      = 0.10f + skin_warm;
        active_shadow_cool    = 0.25f + shadow_cool;
        active_halation       = 0.15f * (halation / 0.2f);
        active_gate_bloom     = 0.10f * (gate_bloom / 0.1f);
        active_highlight_roll  = 0.20f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.10f * (grain_amount / 0.1f);
        active_grain_size     = 1.00f * grain_size;
        active_grain_sat      = 0.30f * (grain_sat / 0.5f);
        active_grain_bias     = 0.00f + grain_bias;
        active_silver_flicker  = 0.08f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.50f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.08f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.10f * (gate_weave / 0.1f);
    } else if (preset == FUJI_SUPERIA) {
        // Fuji Superia 400: Emerald green bias, warm skin tones
        active_contrast       = 0.95f * contrast;
        active_density_c      = 0.32f + (density_c - 0.2f);
        active_density_m      = 0.38f + (density_m - 0.2f);
        active_density_y      = 0.35f + (density_y - 0.2f);
        active_saturation     = 1.10f * saturation;
        active_crosstalk_rg   = -0.08f + crosstalk_rg;
        active_crosstalk_rb   = -0.04f + crosstalk_rb;
        active_crosstalk_gb   = 0.06f + crosstalk_gb;
        active_skin_warm      = 0.20f + skin_warm;
        active_shadow_cool    = 0.15f + shadow_cool;
        active_halation       = 0.30f * (halation / 0.2f);
