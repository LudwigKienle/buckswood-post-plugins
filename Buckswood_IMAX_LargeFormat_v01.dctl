        active_skin_warm      = 0.40f + skin_warm;            // Rich clay terracotta skin look
        active_shadow_cool    = 0.30f + shadow_cool;          // Retro cyan-teal shadows
        active_halation       = 0.20f * (halation / 0.2f);
        active_gate_bloom     = 0.25f * (gate_bloom / 0.1f);
        active_highlight_roll = 0.30f * (highlight_roll / 0.2f);
