        active_grain_sat      = 0.30f * (grain_sat / 0.5f);
        active_grain_bias     = -0.20f + grain_bias;
        active_silver_flicker = 0.20f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.30f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.25f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.30f * (gate_weave / 0.1f);
    } else if (preset == IMAX_1570_CLEAN) {
        // IMAX 15/70 Clean: dense large-format contrast, protected whites, almost no texture drift
        active_contrast       = 1.20f * contrast;
        active_density_c      = 0.18f + (density_c - 0.2f) * 0.35f;
        active_density_m      = 0.20f + (density_m - 0.2f) * 0.35f;
        active_density_y      = 0.17f + (density_y - 0.2f) * 0.35f;
        active_saturation     = 1.03f * saturation;
        active_crosstalk_rg   = 0.01f + crosstalk_rg * 0.25f;
        active_crosstalk_rb   = 0.00f + crosstalk_rb * 0.25f;
        active_crosstalk_gb   = 0.02f + crosstalk_gb * 0.25f;
        active_skin_warm      = 0.08f + skin_warm * 0.35f;
        active_shadow_cool    = 0.12f + shadow_cool * 0.35f;
        active_halation       = 0.05f * (halation / 0.2f);
        active_gate_bloom     = 0.05f * (gate_bloom / 0.1f);
        active_highlight_roll = 0.70f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.02f * (grain_amount / 0.1f);
        active_grain_size     = 0.65f * grain_size;
