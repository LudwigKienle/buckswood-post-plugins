        active_crosstalk_rg   = -0.03f + crosstalk_rg * 0.25f;
        active_crosstalk_rb   = 0.01f + crosstalk_rb * 0.25f;
        active_crosstalk_gb   = 0.07f + crosstalk_gb * 0.25f;
        active_skin_warm      = 0.04f + skin_warm * 0.30f;
        active_shadow_cool    = 0.35f + shadow_cool * 0.35f;
        active_halation       = 0.08f * (halation / 0.2f);
        active_gate_bloom     = 0.12f * (gate_bloom / 0.1f);
