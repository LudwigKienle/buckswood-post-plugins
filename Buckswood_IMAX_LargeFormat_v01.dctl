    } else if (preset == IMAX_WARM_PRINT) {
        // IMAX Warm Print: clean large-format scale with a restrained warm photochemical print bias
        active_contrast       = 1.15f * contrast;
        active_density_c      = 0.22f + (density_c - 0.2f) * 0.35f;
        active_density_m      = 0.24f + (density_m - 0.2f) * 0.35f;
        active_density_y      = 0.20f + (density_y - 0.2f) * 0.35f;
        active_saturation     = 1.02f * saturation;
        active_crosstalk_rg   = 0.04f + crosstalk_rg * 0.25f;
        active_crosstalk_rb   = 0.01f + crosstalk_rb * 0.25f;
        active_crosstalk_gb   = -0.02f + crosstalk_gb * 0.25f;
        active_skin_warm      = 0.22f + skin_warm * 0.35f;
        active_shadow_cool    = 0.08f + shadow_cool * 0.30f;
        active_halation       = 0.06f * (halation / 0.2f);
        active_gate_bloom     = 0.05f * (gate_bloom / 0.1f);
        active_highlight_roll = 0.65f * (highlight_roll / 0.2f);
        active_grain_amount   = 0.025f * (grain_amount / 0.1f);
        active_grain_size     = 0.65f * grain_size;
        active_grain_sat      = 0.20f * (grain_sat / 0.5f);
        active_grain_bias     = 0.00f + grain_bias * 0.25f;
        active_silver_flicker = 0.02f * (silver_flicker / 0.1f);
        active_hl_desat       = 0.55f * (hl_desat / 0.2f);
        active_chroma_soft    = 0.04f * (chroma_soft / 0.1f);
        active_gate_weave     = 0.02f * (gate_weave / 0.1f);
    }

    // 1. LUMINANZ BERECHNEN (Basierend auf REC.2020 / DWG Konstanten)
    float luma = 0.2627f * rgb.x + 0.6780f * rgb.y + 0.0593f * rgb.z;

    // 1.5 ADVANCED CHROMA EDGE SOFTENING (Analog Bleed)
    // Applied at the very start to break up pixel-perfect sharp digital boundaries
    if (active_chroma_soft > 0.0f) {
        float dev = _fabs(rgb.x - rgb.y) + _fabs(rgb.y - rgb.z);
        float edge_hash = hash3d(p_X, p_Y, 99) - 0.5f;
        float bleed = dev * active_chroma_soft * 0.04f * edge_hash;
        rgb.x -= bleed * 0.5f;
        rgb.y += bleed * 0.3f;
        rgb.z += bleed * 0.2f;
    }

    // 2. SUBTRACTIVE CMY DYE LAYER DENSITY (Hollywood Emulation of Subtractive Impurity)
    // Emulates Cyan (absorbing Red), Magenta (absorbing Green), and Yellow (absorbing Blue).
    // Calculates absolute distance of each primary from luminance, and reduces it proportionally.
    if (luma > 0.0f) {
        float dev_r = _fabs(rgb.x - luma);
        float dev_g = _fabs(rgb.y - luma);
        float dev_b = _fabs(rgb.z - luma);
        
        // Red is absorbed by Cyan dye buildup
        rgb.x *= 1.0f - (dev_r * active_density_c * 0.5f);
        // Green is absorbed by Magenta dye buildup
        rgb.y *= 1.0f - (dev_g * active_density_m * 0.5f);
        // Blue is absorbed by Yellow dye buildup
        rgb.z *= 1.0f - (dev_b * active_density_y * 0.5f);
    }

    // 2.3 HOLLYWOOD LOCALIZED 3D HSL WARP (Skin-selective warming & Shadow-selective cooling)
    // Runs inside DaVinci Intermediate log space. Preserves neutrals beautifully.
    {
        // Safe luma clamp
        float clamped_luma = (luma < 0.0f) ? 0.0f : ((luma > 1.0f) ? 1.0f : luma);
        
        // A. Skin Tone Selector Key: Skin tones reside in the peach/orange hue region (R > G > B)
        // Computes a soft, robust weight based on primary separation
        float skin_diff_rg = rgb.x - rgb.y;
        float skin_diff_gb = rgb.y - rgb.z;
        float skin_weight = 0.0f;
        if (skin_diff_rg > 0.0f && skin_diff_gb > 0.0f) {
            float norm = rgb.x * rgb.x + 0.001f;
            skin_weight = (skin_diff_rg * skin_diff_gb) / norm;
            skin_weight = (skin_weight > 1.0f) ? 1.0f : skin_weight;
        }
        
        // Apply localized skin tone warmth warp: shift towards gold/red and desaturate blue
        if (active_skin_warm != 0.0f && skin_weight > 0.0f) {
            rgb.x += 0.04f * active_skin_warm * skin_weight;
            rgb.y += 0.01f * active_skin_warm * skin_weight;
            rgb.z -= 0.02f * active_skin_warm * skin_weight;
        }
        
        // B. Shadow Cooling Selector Key: Peaks in shadows, fades out in midtones
        float shadow_weight = (1.0f - clamped_luma) * (1.0f - clamped_luma);
        
        // Apply localized shadow cooling warp: shift shadows towards filmic teal/blue
        if (active_shadow_cool != 0.0f) {
            rgb.z += 0.03f * active_shadow_cool * shadow_weight;
            rgb.y += 0.005f * active_shadow_cool * shadow_weight; // Add a touch of green for teal balance
            rgb.x -= 0.015f * active_shadow_cool * shadow_weight;
        }
    }

    // 2.5 SUBTRACTIVE FILM DYE CROSSTALK (Impurity Emulation of Analog Layers)
    // Mixes colors inside DWG. Row-sum normalized to 1.0 to preserve neutrals exactly.
    float r_mix = (1.0f - active_crosstalk_rg - active_crosstalk_rb) * rgb.x + active_crosstalk_rg * rgb.y + active_crosstalk_rb * rgb.z;
    float g_mix = active_crosstalk_rg * 0.5f * rgb.x + (1.0f - active_crosstalk_rg * 0.5f - active_crosstalk_gb) * rgb.y + active_crosstalk_gb * rgb.z;
    float b_mix = active_crosstalk_rb * 0.5f * rgb.x + active_crosstalk_gb * 0.5f * rgb.y + (1.0f - active_crosstalk_rb * 0.5f - active_crosstalk_gb * 0.5f) * rgb.z;
    rgb = make_float3(r_mix, g_mix, b_mix);

    // 3. SCENE-REAKTIVER KONTRAST (Sigmoid / S-Kurve im Log-Raum)
    // Ein sanfter mathematischer Roll-off, der Highlights schützt und Schatten nicht absaufen lässt
    if (active_contrast != 1.0f) {
        // Pivot-Punkt auf ca. 18% Grau im Log-Raum ansetzen (DWG Intermediate Mitte liegt bei ~0.34)
        float pivot = 0.336f; 
        
        rgb.x = pivot + _powf(_fmaxf(0.0f, rgb.x / pivot), active_contrast) * pivot - pivot;
        rgb.y = pivot + _powf(_fmaxf(0.0f, rgb.y / pivot), active_contrast) * pivot - pivot;
        rgb.z = pivot + _powf(_fmaxf(0.0f, rgb.z / pivot), active_contrast) * pivot - pivot;
    }

    // 4. GLOBALE SÄTTIGUNGS-ANPASSUNG (Linearer Shift)
    luma = 0.2627f * rgb.x + 0.6780f * rgb.y + 0.0593f * rgb.z;
    rgb.x = luma + active_saturation * (rgb.x - luma);
    rgb.y = luma + active_saturation * (rgb.y - luma);
    rgb.z = luma + active_saturation * (rgb.z - luma);

    // 4.5 SUBTRACTIVE DYE HALATION EMULATION (Highlight Orange-Red Bloom)
    // Runs in DWG intermediate log-space.
    if (active_halation > 0.0f) {
        // Safe luma clamp using fast conditional branching
        float clamped_luma = (luma < 0.0f) ? 0.0f : ((luma > 1.0f) ? 1.0f : luma);
        
        // Generate highlight key mask that starts at 0.336 luma (18% gray pivot) and grows quadratically to 1.0 at 0.486
        float hal_mask = _powf(_fminf(1.0f, _fmaxf(0.0f, (clamped_luma - 0.336f) / 0.15f)), 2.0f);
        
        // Boost Red and Green channels inside highlight mask to generate the warm orange halation bloom
        rgb.x += 0.30f * active_halation * hal_mask;
        rgb.y += 0.09f * active_halation * hal_mask;
    }

    // 4.6 HIGHLIGHT LENS GATE BLOOM EMULATION
    // Replicates photographic light scatter on the silver halide emulsion.
    if (active_gate_bloom > 0.0f) {
        float clamped_luma = (luma < 0.0f) ? 0.0f : ((luma > 1.0f) ? 1.0f : luma);
        
        // Highlights-only mask (threshold at 0.36 luma, grows quadratically to 1.0 at 0.50)
        float bloom_mask = _powf(_fminf(1.0f, _fmaxf(0.0f, (clamped_luma - 0.36f) / 0.14f)), 2.0f);
        
        // Emulate soft highlight flare with a highly aesthetic golden-orange wash
        rgb.x += 0.22f * active_gate_bloom * bloom_mask;
        rgb.y += 0.12f * active_gate_bloom * bloom_mask;
        rgb.z += 0.04f * active_gate_bloom * bloom_mask;
    }

    // 4.7 CINEMATIC HIGHLIGHT SOFT ROLL-OFF (Shoulder Compand Curve)
    // Smoothly compresses high-exposure values asymptotically into paper-white to prevent digital clipping.
    if (active_highlight_roll > 0.0f) {
        // Set the roll-off knee point. DWG 18% gray is 0.336f, display white is at ~0.50f.
        float knee = 0.42f; 
        
        if (rgb.x > knee) {
            rgb.x = knee + (rgb.x - knee) / (1.0f + (rgb.x - knee) * active_highlight_roll * 10.0f);
        }
        if (rgb.y > knee) {
            rgb.y = knee + (rgb.y - knee) / (1.0f + (rgb.y - knee) * active_highlight_roll * 10.0f);
        }
        if (rgb.z > knee) {
            rgb.z = knee + (rgb.z - knee) / (1.0f + (rgb.z - knee) * active_highlight_roll * 10.0f);
        }
    }

    // 4.8 HIGHLIGHT DESATURATION & LUMA-SAT COMPRESSION (Filmic Highlight Washout)
    // Prevents "neon" oversaturated highlights by washing colors to white near clipping boundaries
    if (active_hl_desat > 0.0f) {
        float current_luma = 0.2627f * rgb.x + 0.6780f * rgb.y + 0.0593f * rgb.z;
        if (current_luma > 0.45f) {
            float sat_factor = 1.0f - (current_luma - 0.45f) * active_hl_desat * 2.0f;
            sat_factor = (sat_factor < 0.0f) ? 0.0f : sat_factor;
            rgb.x = current_luma + sat_factor * (rgb.x - current_luma);
            rgb.y = current_luma + sat_factor * (rgb.y - current_luma);
            rgb.z = current_luma + sat_factor * (rgb.z - current_luma);
        }
    }

    // 4.9 DYNAMIC SILVER DENSITY FLICKER & ORGANIC EXPOSURE BREATHING
    // Synthesizes dynamic density fluctuations based on pixel coordinate hash
    if (active_silver_flicker > 0.0f) {
        // Generate a high-frequency spatial seed reacting to the current pixel values
        float spatial_hash = hash3d(p_X, p_Y, 77) - 0.5f;
        
        // Subtle micro-breathing scale (+/- 0.03 stops of exposure)
        float flicker_mod = 1.0f + spatial_hash * active_silver_flicker * 0.03f;
        
        rgb.x *= flicker_mod;
        rgb.y *= flicker_mod;
        rgb.z *= flicker_mod;
    }

    // 5. SCENE-REAKTIVER FILM GRAIN (Livegrain-inspired Multi-layer system)
    // Applied in DWG/Intermediate log-space to ensure smooth highlight/shadow roll-off.
    if (active_grain_amount > 0.0f) {
        // A. Calculate the pixel's current luminance using Rec.2020 weights specified in spec
        float final_luma = 0.2627f * rgb.x + 0.6780f * rgb.y + 0.0593f * rgb.z;
        
        // Clamp luma safely to [0.0, 1.0] using pure conditionals to prevent math intrinsic errors
        float clamped_luma = (final_luma < 0.0f) ? 0.0f : ((final_luma > 1.0f) ? 1.0f : final_luma);
        
        // B. Generate exposure-reactive grain luma mask (Power-skew model)
        // Continuous skew: grain_bias < 0 shifts peak to shadows, grain_bias > 0 shifts to highlights.
        float skew_power = 1.0f + active_grain_bias * 1.0f; // Range: [0.0f, 2.0f]
        skew_power = (skew_power < 0.1f) ? 0.1f : skew_power; // Avoid negative powers or zero-division
        
        // Protect against NaN inside _powf if base is exactly 0.0f (deep shadows)
        float skewed_luma = (clamped_luma > 0.0f) ? _powf(clamped_luma, skew_power) : 0.0f;
        
        // Parabolic mask peaks precisely at skewed_luma = 0.5 and drops to zero at highlights/shadows
        float grain_mask = 4.0f * skewed_luma * (1.0f - skewed_luma);
        
        // C. Calculate temporal z_seed and safe grain size coordinates
        int z_seed = (int)(active_grain_seed * 1000.0f) + TIMELINE_FRAME_INDEX;
        float safe_size = (active_grain_size > 0.01f) ? active_grain_size : 1.0f;
        float gx = (float)p_X / safe_size;
        float gy = (float)p_Y / safe_size;
        
        float gx_floor = (float)((int)gx);
        float gy_floor = (float)((int)gy);
        
        int ix = (int)gx_floor;
        int iy = (int)gy_floor;
        
        float fx = gx - gx_floor;
        float fy = gy - gy_floor;
        
        // D. Bilinear Interpolation for Red channel (z_seed + 1)
        float r_noise_00 = hash3d(ix,     iy,     z_seed + 1);
        float r_noise_10 = hash3d(ix + 1, iy,     z_seed + 1);
        float r_noise_01 = hash3d(ix,     iy + 1, z_seed + 1);
        float r_noise_11 = hash3d(ix + 1, iy + 1, z_seed + 1);
        float r_noise_top = r_noise_00 * (1.0f - fx) + r_noise_10 * fx;
        float r_noise_bot = r_noise_01 * (1.0f - fx) + r_noise_11 * fx;
        float r_noise = (r_noise_top * (1.0f - fy) + r_noise_bot * fy) - 0.5f;
        
        // E. Bilinear Interpolation for Green channel (z_seed + 2)
        float g_noise_00 = hash3d(ix,     iy,     z_seed + 2);
        float g_noise_10 = hash3d(ix + 1, iy,     z_seed + 2);
        float g_noise_01 = hash3d(ix,     iy + 1, z_seed + 2);
        float g_noise_11 = hash3d(ix + 1, iy + 1, z_seed + 2);
        float g_noise_top = g_noise_00 * (1.0f - fx) + g_noise_10 * fx;
        float g_noise_bot = g_noise_01 * (1.0f - fx) + g_noise_11 * fx;
        float g_noise = (g_noise_top * (1.0f - fy) + g_noise_bot * fy) - 0.5f;
        
        // F. Bilinear Interpolation for Blue channel (z_seed + 3)
        float b_noise_00 = hash3d(ix,     iy,     z_seed + 3);
        float b_noise_10 = hash3d(ix + 1, iy,     z_seed + 3);
        float b_noise_01 = hash3d(ix,     iy + 1, z_seed + 3);
        float b_noise_11 = hash3d(ix + 1, iy + 1, z_seed + 3);
        float b_noise_top = b_noise_00 * (1.0f - fx) + b_noise_10 * fx;
        float b_noise_bot = b_noise_01 * (1.0f - fx) + b_noise_11 * fx;
        float b_noise = (b_noise_top * (1.0f - fy) + b_noise_bot * fy) - 0.5f;
        
        // G. Blend monochromatic and color-split grain (Grain Saturation)
        float mono_noise = 0.2627f * r_noise + 0.6780f * g_noise + 0.0593f * b_noise;
        r_noise = mono_noise + active_grain_sat * (r_noise - mono_noise);
        g_noise = mono_noise + active_grain_sat * (g_noise - mono_noise);
        b_noise = mono_noise + active_grain_sat * (b_noise - mono_noise);
        
        // F. Apply noise ADDITIVELY in Log-space (Standard Halide respond model)
        // Highly organic, prevents pixel crushing and exposure clipping during display conversions
        rgb.x = rgb.x + r_noise * active_grain_amount * grain_mask * 0.15f;
        rgb.y = rgb.y + g_noise * active_grain_amount * grain_mask * 0.15f;
        rgb.z = rgb.z + b_noise * active_grain_amount * grain_mask * 0.15f;
    }

    // 5.5 MECHANICAL MICRO GATE WEAVE EMULATION
    // Emulates subtle camera-gate motion and lens vignetting/shading shifts
    if (active_gate_weave > 0.0f) {
        float dist_x = (float)p_X / (float)p_Width - 0.5f;
        float dist_y = (float)p_Y / (float)p_Height - 0.5f;
        float rad = dist_x * dist_x + dist_y * dist_y;
        float weave_mod = _sinf(77.0f * rad + 12.0f) * 0.004f * active_gate_weave;
        rgb.x *= 1.0f - weave_mod * 1.5f;
        rgb.y *= 1.0f - weave_mod * 1.0f;
        rgb.z *= 1.0f - weave_mod * 0.5f;
    }

    // ----------------------------------------------------------------
    // OUTPUT COLOR SPACE CONVERSION (Auto-Encoding to Display)
    // ----------------------------------------------------------------
    if (output_space != BYPASS_OUT) {
        // Decode DWG Intermediate log curve back to scene-linear
        float r_lin = di_to_linear(rgb.x);
        float g_lin = di_to_linear(rgb.y);
        float b_lin = di_to_linear(rgb.z);
        
        if (output_space == REC709_OUT) {
            // DWG to Rec.709 Primaries Mapping
            float r_out = 1.89831313f * r_lin - 0.79205028f * g_lin - 0.10642184f * b_lin;
            float g_out = -0.16895292f * r_lin + 1.48901017f * g_lin - 0.32003433f * b_lin;
            float b_out = -0.12156832f * r_lin - 0.31575157f * g_lin + 1.43755990f * b_lin;
            
            rgb.x = linear_to_gamma24(r_out);
            rgb.y = linear_to_gamma24(g_out);
            rgb.z = linear_to_gamma24(b_out);
        } else if (output_space == REC2020_OUT) {
            // DWG to Rec.2020 Primaries Mapping
            float r_out = 1.13030218f * r_lin - 0.02039300f * g_lin - 0.10990924f * b_lin;
            float g_out = -0.02554667f * r_lin + 1.31084962f * g_lin - 0.28530290f * b_lin;
            float b_out = -0.09259861f * r_lin - 0.16465342f * g_lin + 1.25725180f * b_lin;
            
            rgb.x = linear_to_gamma24(r_out);
            rgb.y = linear_to_gamma24(g_out);
            rgb.z = linear_to_gamma24(b_out);
        } else if (output_space == DCIP3_OUT) {
            // DWG to DCI-P3 (D65) Primaries Mapping
            float r_out = 1.53154395f * r_lin - 0.38718504f * g_lin - 0.14435886f * b_lin;
            float g_out = -0.10031783f * r_lin + 1.41325484f * g_lin - 0.31293703f * b_lin;
            float b_out = -0.09046194f * r_lin - 0.19316362f * g_lin + 1.28362561f * b_lin;
            
            rgb.x = linear_to_gamma26(r_out);
            rgb.y = linear_to_gamma26(g_out);
            rgb.z = linear_to_gamma26(b_out);
        }
    }

    // Schutz vor illegalen Werten (Clipping-Guard & Signal Integrity)
    rgb.x = _fmaxf(0.0f, rgb.x);
    rgb.y = _fmaxf(0.0f, rgb.y);
    rgb.z = _fmaxf(0.0f, rgb.z);

    return rgb;
}
